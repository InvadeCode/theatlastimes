rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /articles/{articleId} {
      allow read: if true;
      allow write: if true; 
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /briefcases/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
